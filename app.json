{
  "expo": {
    "name": "Dim-Dong",
    "slug": "dim-dong",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dimdong",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": false,
      "bundleIdentifier": "com.refreshstory.dimdong",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5F1E8"
        }
      ],
      "expo-audio"
    ],
    "updates": {
      "url": "https://u.expo.dev/a2232c18-6032-452a-ba78-404800b94c33"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "hedu",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2232c18-6032-452a-ba78-404800b94c33"
      }
    }
  }
}
