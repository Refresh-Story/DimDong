rules_version = '2';

// Storage de Dim-Dong.
// Les visuels du catalogue (PNG des objets achetables) sont en lecture publique
// pour pouvoir être affichés par l'app sans authentification particulière.
// L'écriture est interdite côté client : les uploads se font via le SDK Admin
// (script scripts/render-items.mjs), comme pour la collection Firestore `catalog`.
service firebase.storage {
  match /b/{bucket}/o {
    match /catalog/{image=**} {
      allow read: if true;
      allow write: if false;
    }
    // Tout le reste est fermé par défaut.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
